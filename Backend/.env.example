# Server Configuration
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/edusync
SIMILARITY_THRESHOLD=0.7
USE_AI=false

# AI Configuration
# For Google Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
